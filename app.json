{
  "name": "Glossa",
  "description": "Managed MCP relay for local coding workspaces.",
  "repository": "https://github.com/ariobarin/glossa",
  "keywords": [
    "mcp",
    "developer-tools",
    "agent"
  ],
  "env": {
    "GLOSSA_PUBLIC_ORIGIN": {
      "required": true
    },
    "GLOSSA_AUTH0_ISSUER": {
      "required": true
    },
    "GLOSSA_AUTH0_AUDIENCE": {
      "required": true
    },
    "GLOSSA_AUTH0_CLI_CLIENT_ID": {
      "required": true
    },
    "GLOSSA_MCP_REQUIRED_SCOPE": {
      "value": "glossa:access"
    },
    "GLOSSA_DEVICE_ENROLL_SCOPE": {
      "value": "glossa:device"
    },
    "GLOSSA_RATE_LIMIT_WINDOW_MS": {
      "value": "60000"
    },
    "GLOSSA_ENROLL_RATE_LIMIT": {
      "value": "10"
    },
    "GLOSSA_DEVICE_AUTH_RATE_LIMIT": {
      "value": "120"
    },
    "GLOSSA_WORKER_POLL_MS": {
      "value": "15000"
    },
    "GLOSSA_COMMAND_TIMEOUT_MS": {
      "value": "15000"
    }
  },
  "addons": [
    "heroku-postgresql:essential-0"
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ]
}
