{
  "name": "@glossa/relay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=../../.env dist/src/index.js",
    "migrate": "node --env-file-if-exists=../../.env dist/src/migrate.js",
    "test": "npm run build --workspace @glossa/protocol && npm run test:run",
    "test:run": "node -e \"require('node:fs').rmSync('dist-test',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node ../../scripts/run-compiled-tests.mjs dist-test"
  },
  "dependencies": {
    "@glossa/protocol": "*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "jose": "6.2.3",
    "pg": "8.16.3",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.5",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
