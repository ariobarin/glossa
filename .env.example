NODE_ENV=development
GLOSSA_BIND_HOST=127.0.0.1
PORT=39100
DATABASE_URL=postgres://localhost/glossa
GLOSSA_PUBLIC_ORIGIN=http://localhost:39100
GLOSSA_AUTH0_ISSUER=https://YOUR_TENANT.auth0.com/
GLOSSA_AUTH0_AUDIENCE=https://mcp.glossa.sh/
GLOSSA_AUTH0_CLI_CLIENT_ID=PUBLIC_NATIVE_CLIENT_ID
GLOSSA_MCP_REQUIRED_SCOPE=glossa:access
GLOSSA_DEVICE_ENROLL_SCOPE=glossa:device
GLOSSA_RATE_LIMIT_WINDOW_MS=60000
GLOSSA_ENROLL_RATE_LIMIT=10
GLOSSA_DEVICE_AUTH_RATE_LIMIT=120
GLOSSA_WORKER_POLL_MS=15000
GLOSSA_COMMAND_TIMEOUT_MS=900000
