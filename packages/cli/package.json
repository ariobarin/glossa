{
  "name": "@ariobarin/glossa",
  "version": "0.1.0-beta.4",
  "private": false,
  "description": "Connect an explicitly exposed local coding workspace to the Glossa MCP relay.",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "bin": {
    "glossa": "dist/main.js"
  },
  "main": "dist/main.js",
  "files": [
    "dist/main.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && node scripts/build-package.mjs",
    "prepack": "npm run build",
    "test": "npm run build --workspace @glossa/protocol && npm run test:run",
    "test:run": "node -e \"require('node:fs').rmSync('dist-test',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node ../../scripts/run-compiled-tests.mjs dist-test"
  },
  "dependencies": {
    "@napi-rs/keyring": "1.3.0"
  },
  "devDependencies": {
    "@glossa/protocol": "*",
    "@types/node": "24.10.1",
    "esbuild": "0.28.1",
    "typescript": "5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariobarin/glossa.git"
  },
  "homepage": "https://glossa.sh",
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  }
}
